{
  "expo": {
    "name": "Cultura Nacional",
    "slug": "cultura-nacional",
    "version": "1.0.0",
    "scheme": "culturanacional",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "favicon": "./assets/images/favicon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#009C3B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.culturanacional.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#009C3B"
      },
      "package": "com.culturanacional.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-location",
      "expo-notifications",
      "expo-sharing",
      "expo-video",
      "expo-audio",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "O Cultura Nacional precisa de acesso à câmera para o Modo Viral.",
          "microphonePermission": "O Cultura Nacional precisa de acesso ao microfone para gravar vídeos no Modo Viral.",
          "recordAudioAndroid": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "167329d4-bc56-4a13-a57a-ae992ee3ad6b"
      }
    }
  }
}
